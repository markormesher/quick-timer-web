{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "noEmit": true,
    "jsx": "react",
    "types": ["node"],
    "lib": [
      "esnext",
      "webworker",
      "dom"
    ],
    "exactOptionalPropertyTypes": false
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx"
  ]
}
